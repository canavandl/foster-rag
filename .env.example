# Example environment variables for foster_rag project
# Copy this file to .dev.vars for local development

# API key for /upload endpoint authentication
# Generate a secure key with: openssl rand -base64 32
UPLOAD_API_KEY=your-secret-key-here

# Worker URLs for ingestion scripts
WORKER_URL=http://localhost:8787
REMOTE_WORKER_URL=https://foster-care-rag.your-account.workers.dev
